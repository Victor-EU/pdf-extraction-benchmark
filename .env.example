# Copy to `.env` and fill in your own keys. `.env` is gitignored — never commit it.
# Each script reads only the key(s) it needs from this file.

OPENAI_API_KEY=sk-...          # gpt-5 extraction + the fair-total / element judges
GEMINI_API_KEY=...             # Gemini 3.5 Flash / 3.1 Flash-Lite extraction + cross-family judge
LLAMA_CLOUD_API_KEY=llx-...    # LlamaParse (use the `agentic` tier — see AUDIT_LLAMAPARSE_MODE.md)
VISION_AGENT_API_KEY=...       # Landing AI ADE
